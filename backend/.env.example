# Conexión a la base de datos.
# En Supabase: DATABASE_URL usa el pooler (pgBouncer, puerto 6543),
# DIRECT_URL usa la conexión directa (puerto 5432) para migraciones.
# En local, ambas pueden apuntar a la misma base.
DATABASE_URL="postgresql://user:password@localhost:5432/kanban_db"
DIRECT_URL="postgresql://user:password@localhost:5432/kanban_db"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
PORT=3000
